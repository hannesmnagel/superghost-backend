# Copy to .env and fill in real values (.env is gitignored).
NODE_ENV=production
PORT=8080

# --- Postgres (compose "db" service) ---
POSTGRES_USER=superghost
POSTGRES_PASSWORD=changeme
POSTGRES_DB=superghost
PGDATA=/var/lib/postgresql/data/pgdata
# Use the compose service hostname "db" (not localhost) from inside the web container.
DATABASE_URL=postgresql://superghost:changeme@db:5432/superghost

# --- Auth ---
JWT_SECRET=changeme_use_64_hex_chars   # e.g. `openssl rand -hex 32`
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=60
APPLE_BUNDLE_ID=com.nagel.superghost

# --- LLM (OpenRouter) — authoritative for moves/word-checks/definitions ---
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=tencent/hy3-preview
AI_TIMEOUT_MS=12000

# --- OpenAI (handle moderation) ---
OPENAI_API_KEY=sk-proj-...
OPENAI_MODERATION_MODEL=omni-moderation-latest

# --- Gameplay timing (ms) ---
BOT_FILL_MS=5000
TURN_TIMEOUT_MS=30000
RECONNECT_GRACE_MS=60000
